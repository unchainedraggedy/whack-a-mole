        <mxCell id="4bARHQ5OFeReXbWWnOvM-244" parent="1" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#BC6C25;strokeColor=#DDA15E;fontColor=#FEFAE0;" value="Дружелюбная атмосфера" vertex="1">
